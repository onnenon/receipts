# Copy to /etc/receipts/receipts.env on the server and chmod it to 0640.
# Do not commit the real file.

# Phoenix
PHX_HOST=receipts.example.com
SECRET_KEY_BASE=replace-with-output-from-openssl-rand-base64-48
ADMIN_PASSWORD=replace-with-a-long-admin-password

# Database container
POSTGRES_DB=receipts_prod
POSTGRES_USER=receipts
POSTGRES_PASSWORD=replace-with-output-from-openssl-rand-base64-32
POOL_SIZE=10

# Cloudflare Tunnel token from Zero Trust. Configure the public hostname
# service as: http://web:4000
CLOUDFLARED_TOKEN=replace-with-cloudflare-tunnel-token

# Riot Games API
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Discord Application
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# Google Gemini API
GEMINI_API_KEY=
